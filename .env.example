# ===================================
# DATABASE (Koyeb PostgreSQL)
# ===================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=soc
DB_PASSWORD=change-me
DB_DATABASE=soc

# ===================================
# JWT
# ===================================
JWT_SECRET=change-me-to-a-very-long-random-string

# ===================================
# SERVER
# ===================================
PORT=3000

# ===================================
# CORS
# ===================================
CORS_ORIGIN=*

# ===================================
# STORAGE — Supabase Storage (S3-compatible)
# ===================================
# Dùng endpoint từ Supabase Dashboard → API Settings → S3 API
MINIO_ENDPOINT=<project-ref>.supabase.co
MINIO_PORT=9000
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=<s3-access-key>
MINIO_SECRET_KEY=<s3-secret-key>
MINIO_BUCKET=social
