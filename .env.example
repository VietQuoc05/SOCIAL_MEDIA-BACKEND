# ===================================
# DATABASE (Koyeb PostgreSQL)
# ===================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=soc
DB_PASSWORD=change-me
DB_DATABASE=soc

# ===================================
# JWT
# ===================================
JWT_SECRET=change-me-to-a-very-long-random-string

# ===================================
# SERVER
# ===================================
PORT=3000

# ===================================
# CORS
# ===================================
CORS_ORIGIN=*

# ===================================
# STORAGE — Supabase S3-compatible
# ===================================
# Dùng S3 API endpoint + credentials từ Supabase Dashboard → Storage → API
# Lưu ý: bucket phải đã tồn tại trong Supabase Storage
S3_ENDPOINT=<project-ref>.supabase.co
S3_REGION=us-east-1
S3_USE_SSL=true
S3_ACCESS_KEY=<s3-access-key>
S3_SECRET_KEY=<s3-secret-key>
S3_BUCKET=social
# (tuỳ chọn) public URL của bucket, ví dụ: https://<project-ref>.supabase.co/storage/v1/object/public/social
S3_PUBLIC_URL=
